rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== FUNGSI BANTU ====================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin';
    }

    function isHR() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'hr';
    }

    function isAdmin() {
      let role = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return role == 'admin' || role == 'super_admin';
    }

    function isSPV() {
      let role = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return role == 'spv' || role == 'manager' || role == 'super_admin' || role == 'admin' || role == 'hr';
    }

    function isSameUser(userId) {
      return request.auth.uid == userId;
    }

    // ==================== ABOUT & APP SETTINGS (PUBLIC READ) ====================
    match /about/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && isAdmin();
    }

    match /appinfo/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && isAdmin();
    }

    function isModifyingRestrictedFields() {
      // Prevents users from escalating their own privileges or changing critical HR data
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'department', 'employeeId', 'salary', 'isActive']);
    }

    // ==================== USERS COLLECTION ====================
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (
        isSuperAdmin() || 
        isHR() || 
        (isSameUser(userId) && !isModifyingRestrictedFields())
      );
      allow delete: if isAuthenticated() && isSuperAdmin();
    }

    // ==================== ATTENDANCE ====================
    match /attendance/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.uid == request.auth.uid || isSPV());
      allow delete: if isAuthenticated() && isSuperAdmin();
    }

    match /attendance_requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && isSPV();
    }

    // ==================== LOCATION TRACKING ====================
    match /user_locations/{userId} {
      allow read: if isAuthenticated() && (isSameUser(userId) || isSuperAdmin() || isAdmin() || isSPV());
      allow create: if isAuthenticated() && isSameUser(userId);
      allow update: if isAuthenticated() && (isSameUser(userId) || isSuperAdmin() || isAdmin() || isSPV());
      allow delete: if isAuthenticated() && (isSameUser(userId) || isSuperAdmin());
    }

    match /user_locations_history/{userId} {
      allow read: if isAuthenticated() && (isSameUser(userId) || isSuperAdmin() || isAdmin() || isSPV());
      allow create: if isAuthenticated() && isSameUser(userId);
      match /{subCollection}/{subDocId} {
        allow read: if isAuthenticated() && (isSameUser(userId) || isSuperAdmin() || isAdmin() || isSPV());
        allow create: if isAuthenticated() && isSameUser(userId);
      }
    }

    match /live_location/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // ==================== NOTIFICATIONS ====================
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ==================== SETTINGS ====================
    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();
    }

    match /app_settings/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && isAdmin();
    }

    match /approval_settings/{department} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();
    }

    // ==================== SHIFTS ====================
    match /shift_schedules/{scheduleId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && (isSuperAdmin() || isHR());
    }

    match /shifts/{shiftId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isSuperAdmin() || isHR());
      allow update: if isAuthenticated() && (isSuperAdmin() || isHR());
      allow delete: if isAuthenticated() && isSuperAdmin();
    }

    match /shift_audit_logs/{logId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isHR());
      allow create: if isAuthenticated() && (isSuperAdmin() || isHR());
      allow update: if isAuthenticated() && (isSuperAdmin() || isHR());
      allow delete: if isAuthenticated() && isSuperAdmin();
    }

    // ==================== MEETINGS & BRIEFINGS ====================
    match /meetings/{meetingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.createdBy == request.auth.uid || isSuperAdmin() || isAdmin());
      allow delete: if isAuthenticated() && isSuperAdmin();
    }

    match /meetings/{meetingId}/tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && isSuperAdmin();
    }

    match /briefings/{briefingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.createdBy == request.auth.uid || isSuperAdmin() || isAdmin());
      allow delete: if isAuthenticated() && isSuperAdmin();
    }

    // ==================== ASSESSMENT ====================
    match /assessmentPeriods/{periodId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isSuperAdmin() || isHR());
      allow update: if isAuthenticated() && (isSuperAdmin() || isHR());
      allow delete: if isAuthenticated() && isSuperAdmin();
    }

    match /assessments/{assessmentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isSuperAdmin() || isHR() || isSPV());
      allow update: if isAuthenticated() && (isSuperAdmin() || isHR() || isSPV());
      allow delete: if isAuthenticated() && isSuperAdmin();
    }

    // ==================== PAYROLL ====================
    match /payroll/{payrollId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isSuperAdmin() || isHR());
      allow update: if isAuthenticated() && (isSuperAdmin() || isHR());
      allow delete: if isAuthenticated() && isSuperAdmin();
    }

    // 🔥 PAYROLL PAYMENTS (untuk payment status feature)
    match /payroll_payments/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isSuperAdmin() || isHR() || isAdmin());
      allow update: if isAuthenticated() && (isSuperAdmin() || isHR() || isAdmin());
      allow delete: if isAuthenticated() && isSuperAdmin();
    }

    // ==================== KPI ====================
    match /kpis/{kpiId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isSuperAdmin() || isHR());
      allow update: if isAuthenticated() && (isSuperAdmin() || isHR());
      allow delete: if isAuthenticated() && isSuperAdmin();
    }

    // ==================== ARTICLES / PENGUMUMAN ====================
    match /articles/{articleId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isSuperAdmin() || isAdmin() || isHR());
      allow update: if isAuthenticated() && (isSuperAdmin() || isAdmin() || isHR());
      allow delete: if isAuthenticated() && isSuperAdmin();
    }

    // ==================== MANAGER ON DUTY ====================
    match /mod_schedules/{scheduleId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isSuperAdmin() || isAdmin() || isHR());
      allow update: if isAuthenticated() && (isSuperAdmin() || isAdmin() || isHR());
      allow delete: if isAuthenticated() && isSuperAdmin();
    }

    match /mod_templates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isSuperAdmin() || isAdmin() || isHR());
    }

    match /mod_reports/{reportId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.createdBy == request.auth.uid || isSuperAdmin() || isAdmin() || isHR());
      allow delete: if isAuthenticated() && isSuperAdmin();
    }

    // ==================== WORK ORDERS ====================
    match /work_orders/{woId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isSPV();
      allow update: if isAuthenticated() && (
        resource.data.createdBy == request.auth.uid ||
        isSPV()
      );
      allow delete: if isAuthenticated() && isSuperAdmin();
    }

    match /wo_inventory_templates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isSuperAdmin() || isAdmin() || isHR() || isSPV() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager');
    }

    match /role_permissions/{roleId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /work_threads/{threadId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ==================== INTERNAL MEMO ====================
    match /internal_memos/{memoId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.createdBy == request.auth.uid || isSPV());
      allow delete: if isAuthenticated() && isSuperAdmin();
    }

    // ==================== CALL SIGNALING ====================
    match /active_calls/{callId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ==================== CHAT & MESSAGING ====================
    match /conversations/{conversationId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    match /user_conversations/{userId}/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ==================== MASTER DATA ====================
    match /departments/{departmentId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() || isAdmin();
    }

  }
}